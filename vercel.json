{
    "version": 2,
    "cleanUrls": true,
    "routes": [
        {
            "src": "/api/status",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/events",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        }
    ]
}